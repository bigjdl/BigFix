<?xml version="1.0" encoding="UTF-8"?>
<BES xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="BES.xsd">
	<Task>
		<Title>Run All Windows Office Fixlets - Parameterized MAG</Title>
		<Description><![CDATA[<P><STRONG><FONT size=3>Action&nbsp;Parameters:</FONT></STRONG></P>
<P>&nbsp;<INPUT onfocus="if (this.value == 'OP Name') {this.value = '';}" onblur="if (this.value == '') {this.value = 'OP Name';}" id=RemoteOP title="Enter the Operator Name with API Rights" value="OP Name" name=RemoteOP>&nbsp;<FONT color=#0080ff><STRONG>&lt;&lt;&nbsp;</STRONG></FONT> Enter the&nbsp;Bigfix Server Operator Name<BR>&nbsp;<INPUT id=RemoteOPPass title="Enter the Operator Password" type=password name=RemoteOPPass>&nbsp;&nbsp; <FONT color=#0080ff><STRONG>&lt;&lt;</STRONG></FONT>&nbsp; Enter the&nbsp;Bigfix Server Operator Password&nbsp;<BR><script>
			document.body.ontakeaction = function() {
				var theRemoteOP = document.getElementById( "RemoteOP" ).value;
				var theRemoteOPPass = document.getElementById( "RemoteOPPass" ).value;
				TakeSecureFixletAction( Relevance('id of current fixlet'), Relevance('id of current bes site'), "Action1", {}, { RemoteOP: theRemoteOP , RemoteOPPass: theRemoteOPPass } );
				return false;
			}
			</script><BR><STRONG>_____________________________________________________________________________________________________</STRONG> </P>
<P><SPAN lang=EN><STRONG><FONT size=3><U></U></FONT></STRONG></SPAN>&nbsp;</P>
<P><SPAN lang=EN><FONT size=3>Will run the Windows Office365 Updates, it will force apps to close.</FONT></SPAN></P>
<P><SPAN lang=EN><STRONG><FONT size=3><U>Prerequisites:</U></FONT><BR>It will also&nbsp;need&nbsp;Curl installed. NOTE: As of Windows 10 build 1803, Curl is already installed and located in the System32 directory.</STRONG></SPAN><SPAN lang=EN></P></SPAN>]]></Description>
		<Relevance><![CDATA[version of client >= "9.0"]]></Relevance>
		<Relevance>exists main gather service</Relevance>
		<Category>Update</Category>
		<Source>jared.levy@hcl-software.com - This content is to be used at your own risk.  </Source>
		<SourceID></SourceID>
		<SourceReleaseDate>2026-03-12</SourceReleaseDate>
		<SourceSeverity></SourceSeverity>
		<CVENames></CVENames>
		<SANSID></SANSID>
		<MIMEField>
			<Name>x-fixlet-modification-time</Name>
			<Value>Thu, 12 Mar 2026 23:11:50 +0000</Value>
		</MIMEField>
		<Domain>BESC</Domain>
		<DefaultAction ID="Action1">
			<Description>
				<PreLink>Click </PreLink>
				<Link>here</Link>
				<PostLink> to deploy this action.</PostLink>
			</Description>
			<ActionScript MIMEType="application/x-Fixlet-Windows-Shell"><![CDATA[//Pathname to curl
action parameter query "cURL" with description "Please enter the full path to curl binary" with default value "%22C:\Windows\System32\curl.exe%22"

//IP or Hostname and PORT of Bigfix Server:
action parameter query "BFServer" with description "Please enter the IP address or Hostname and Port of the Bigfix REST API (must be resolvable):" with default value "11.11.11.11:52311"

//Check for C:\export
if {not exist folder "c:\export"}
	dos mkdir "c:\export"
endif

delete "c:\export\run.xml"
delete "c:\export\winofficeID.txt"
delete "c:\export\winofficeid.xml"
delete __appendfile
delete __createfile


//Get relevant macoffice fixlet IDs
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(name%20of%20it%2C%20id%20of%20it)%20of%20it%20whose%20%20((fixlet%20flag%20of%20it%20%3D%20true)%20and%20(name%20of%20it%20as%20lowercase%20contains%20%22office%22)%20and%20(display%20name%20of%20site%20of%20it%20%3D%22Patches%20for%20Windows%22)%20and%20(not(name%20of%20it%20as%20lowercase%20contains%20%22super%22))and%20(if%20name%20of%20it%20as%20lowercase%20contains%20%22365%22%20then%20(name%20of%20it%20as%20lowercase%20contains%20%22english%20(united%20states)%22)%20else%20(true))%20and%20(source%20release%20date%20of%20it%20%3E%20(current%20date%20-%20730*day))and%20(category%20of%20it%20contains%20%22Update%22)%20and%20(exists%20content%20ids%20whose%20(it%20%3D%20%22Action6%22)%20%20of%20actions%20of%20it)%20)%20of%20unique%20values%20of%20elements%20of%20relevant%20fixlet%20sets%20of%20bes%20computers%20"  https://{parameter "BFServer" of action}/api/query -o "c:\export\winofficeID.xml"

//Strip XML
delete __appendfile
appendfile {concatenation "%0d%0a" of (preceding texts of firsts "</Answer>" of (following texts of firsts "type=%22integer%22>" of (lines whose (it contains "<Answer type=%22integer%22>") of file "c:\export\winofficeID.xml")))}
move __appendfile "c:\export\winofficeID.txt"

//Create XML File
createfile until "FINE"
<?xml version="1.0" encoding="UTF-8"?>
<BES xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="BES.xsd">
<MultipleActionGroup>
<Title>Upgrade Win Office Action 6</Title>
<Relevance>True</Relevance>
  <SourcedMemberAction>
    <SourceFixlet>    
      <Sitename>Patches for Windows</Sitename>    
        <FixletID>{concatenation "</FixletID>%0d%0a<Action>Action6</Action>%0d%0a</SourceFixlet>%0d%0a</SourcedMemberAction>%0d%0a<SourcedMemberAction>%0d%0a<SourceFixlet>%0d%0a<Sitename>Patches for Windows</Sitename>%0d%0a<FixletID>" of (lines of file "C:\export\winofficeID.txt")}</FixletID>    
        <Action>Action6</Action>  
    </SourceFixlet>  
  </SourcedMemberAction> 
    <Target>    
            <AllComputers>true</AllComputers>
    </Target>
</MultipleActionGroup>
</BES>

"FINE"

copy __createfile "c:\export\run.xml"

//Run Action
wait {parameter "cURL" of action} -k -X POST --data-binary @c:\export\run.xml --user {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} https://{parameter "BFServer" of action}/api/actions

delete "c:\export\run2.xml"
delete "c:\export\winofficeID2.txt"
delete "c:\export\winofficeid2.xml"
delete __appendfile
delete __createfile


//Get relevant macoffice fixlet IDs
wait {parameter "cURL" of action} -k -u {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} -X POST -d "relevance=(name%20of%20it%2C%20id%20of%20it)%20of%20it%20whose%20%20((fixlet%20flag%20of%20it%20%3D%20true)%20and%20(name%20of%20it%20as%20lowercase%20contains%20%22office%22)%20and%20(display%20name%20of%20site%20of%20it%20%3D%22Patches%20for%20Windows%22)%20and%20(not(name%20of%20it%20as%20lowercase%20contains%20%22super%22))and%20(if%20name%20of%20it%20as%20lowercase%20contains%20%22365%22%20then%20(name%20of%20it%20as%20lowercase%20contains%20%22english%20(united%20states)%22)%20else%20(true))%20and%20(source%20release%20date%20of%20it%20%3E%20(current%20date%20-%20730*day))and%20(category%20of%20it%20contains%20%22Update%22)%20and%20%20(not(exists%20content%20ids%20whose%20(it%20%3D%20%22Action6%22)%20%20of%20actions%20of%20it))%20and%20(exists%20content%20ids%20whose%20(it%20%3D%20%22Action3%22)%20%20of%20actions%20of%20it)%20)%20of%20unique%20values%20of%20elements%20of%20relevant%20fixlet%20sets%20of%20bes%20computers%20"  https://{parameter "BFServer" of action}/api/query -o "c:\export\winofficeID2.xml"

//Strip XML
delete __appendfile
appendfile {concatenation "%0d%0a" of (preceding texts of firsts "</Answer>" of (following texts of firsts "type=%22integer%22>" of (lines whose (it contains "<Answer type=%22integer%22>") of file "c:\export\winofficeID2.xml")))}
move __appendfile "c:\export\winofficeID2.txt"

//Create XML File
createfile until "FINE"
<?xml version="1.0" encoding="UTF-8"?>
<BES xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="BES.xsd">
<MultipleActionGroup>
<Title>Upgrade Win Office Action 3</Title>
<Relevance>True</Relevance>
  <SourcedMemberAction>
    <SourceFixlet>    
      <Sitename>Patches for Windows</Sitename>    
        <FixletID>{concatenation "</FixletID>%0d%0a<Action>Action3</Action>%0d%0a</SourceFixlet>%0d%0a</SourcedMemberAction>%0d%0a<SourcedMemberAction>%0d%0a<SourceFixlet>%0d%0a<Sitename>Patches for Windows</Sitename>%0d%0a<FixletID>" of (lines of file "C:\export\winofficeID2.txt")}</FixletID>    
        <Action>Action3</Action>  
    </SourceFixlet>  
  </SourcedMemberAction> 
    <Target>    
            <AllComputers>true</AllComputers>
    </Target>
</MultipleActionGroup>
</BES>

"FINE"

copy __createfile "c:\export\run2.xml"

//Run Action
wait {parameter "cURL" of action} -k -X POST --data-binary @c:\export\run2.xml --user {parameter "RemoteOP" of action}:{parameter "RemoteOPPass" of action} https://{parameter "BFServer" of action}/api/actions]]></ActionScript>
		</DefaultAction>
	</Task>
</BES>
